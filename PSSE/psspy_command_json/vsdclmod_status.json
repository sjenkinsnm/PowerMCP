{
  "module": "psspy",
  "function_name": "vsdclmod_status",
  "category": "Dc Line Related Models",
  "description": "Use this API to change the status of the VSC dc line model at a specified VSC dc line. This API routine was first introduced in release 30.2.0. ierr = vsdclmod_status(dcname, status)",
  "python_syntax": "ierr = vsdclmod_status(dcname, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "dcname",
      "description": "Vsc dc line name. (input; no default allowed)."
    },
    {
      "name": "status",
      "description": "New model status. (input; 1 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "status": [
      {
        "value": "= 0",
        "description": "out-of-service."
      },
      {
        "value": "= 1",
        "description": "in-service."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "VSC dc line not found."
    },
    {
      "value": "= 2",
      "description": "no model at this VSC dc line."
    },
    {
      "value": "= 3",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 4",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}