{
  "module": "psspy",
  "function_name": "transaction_delete",
  "category": "Power Flow Data",
  "description": "Use this API to delete a transaction event from PSSE working memory. This API routine was first introduced in release 30.0.0. ierr = transaction_delete(event)",
  "python_syntax": "ierr = transaction_delete(event)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "event",
      "description": "Transaction event number. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error occurred."
    },
    {
      "value": "= 1",
      "description": "invalid transaction event number."
    },
    {
      "value": "= 2",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}