{
  "module": "psspy",
  "function_name": "list",
  "category": "Power Flow Operation",
  "description": "Use this API routine to tabulate the power flow working case in a form suitable for problem data documentation. This API routine was first introduced in release 28.0.0. ierr = list(sid, all, opt, vrev)",
  "python_syntax": "ierr = list(sid, all, opt, vrev)",
  "return_type": "error_only_report",
  "parameters": [
    {
      "name": "sid",
      "description": "A valid subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "opt",
      "description": "Power flow data category to be tabulated. (input; 1 by default)."
    },
    {
      "name": "vrev",
      "description": "Units used for displaying voltages. (input; 0 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      },
      {
        "value": "= 1",
        "description": "process all buses."
      }
    ],
    "opt": [
