{
  "module": "psspy",
  "function_name": "busexs",
  "category": "Single Element Data",
  "description": "Use this API to check for the existence of a specified bus. This API routine was first introduced in release 28.0.0. ierr = busexs(ibus)",
  "python_syntax": "ierr = busexs(ibus)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "Bus found."
    },
    {
      "value": "= 1",
      "description": "Bus not found."
    }
  ]
}