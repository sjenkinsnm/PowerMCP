{
  "module": "psspy",
  "function_name": "vsccin",
  "category": "Single Element Data",
  "description": "Use this API to return VSC dc line converter integer parameters. This API routine was first introduced in release 28.0.0. ierr, ival = vsccin(id, ibus, string)",
  "python_syntax": "ierr, ival = vsccin(id, ibus, string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "id",
      "description": "Vsc dc line name. (input)."
    },
    {
      "name": "ibus",
      "description": "Converter bus number. (input)."
    },
    {
      "name": "string",
      "description": "String indicating the vsc dc line quantity desired. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "ival",
      "description": "Parameter value. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= DCTYPE",
        "description": "Converter dc control code."
      },
      {
        "value": "= ACMODE",
        "description": "Converter ac control mode."
      },
      {
        "value": "= VSREG",
        "description": "Regulated bus."
      },
      {
        "value": "= NREG",
        "description": "Regulated node."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘IVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "VSC dc line ‘ID’ not found; ‘IVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Invalid ‘STRING’; ‘IVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Bus ‘IBUS’ not a converter of this dc line; ‘IVAL’ unchanged."
    }
  ]
}