{
  "module": "psspy",
  "function_name": "ownnam",
  "category": "Single Element Data",
  "description": "Returns the owner name for a specified owner number. This API routine was first introduced in release 28.0.0. ierr, cval = ownnam(iar)",
  "python_syntax": "ierr, cval = ownnam(iar)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "iar",
      "description": "Owner number. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "cval",
      "description": "Owner name. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘CVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Owner number <= 0 or > largest allowable owner number; ‘CVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Owner not found; ‘CVAL’ unchanged."
    }
  ]
}