{
  "module": "psspy",
  "function_name": "purg",
  "category": "Power Flow Data",
  "description": "Use this API routine to delete specified outaged equipment items from the working case. This API routine was first introduced in release 28.0.0. ierr = purg(sid, all, opt, status)",
  "python_syntax": "ierr = purg(sid, all, opt, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "sid",
      "description": "A valid subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "opt",
      "description": "Equipment type to remove. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "Option for the treatment of out-of-service ties to other systems. (input; 0 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      },
      {
        "value": "= 1",
        "description": "process all buses."
      }
    ],
    "opt": [
      {
        "value": "= 1",
        "description": "ac lines."
      },
      {
        "value": "= 2",
        "description": "switched shunts."
      },
      {
        "value": "= 3",
        "description": "machines."
      },
      {
        "value": "= 4",
        "description": "plants."
      },
      {
        "value": "= 5",
        "description": "two-terminal dc lines."
      },
      {
        "value": "= 6",
        "description": "multi-terminal dc lines."
      },
      {
        "value": "= 7",
        "description": "loads."
      },
      {
        "value": "= 8",
        "description": "FACTS devices."
      },
      {
        "value": "= 9",
        "description": "three-winding transformers."
      },
      {
        "value": "= 10",
        "description": "VSC dc lines."
      },
      {
        "value": "= 11",
        "description": "fixed bus shunts."
      },
      {
        "value": "= 12",
        "description": "GNE devices."
      },
      {
        "value": "= 13",
        "description": "induction machines."
      }
    ],
    "status": [
      {
        "value": "= 0",
        "description": "keep out-of-service ties."
      },
      {
        "value": "= 1",
        "description": "remove out-of-service ties."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid SID value or subsystem SID is not defined."
    },
    {
      "value": "= 2",
      "description": "invalid ALL value."
    },
    {
      "value": "= 3",
      "description": "invalid OPT value."
    },
    {
      "value": "= 4",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 5",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}