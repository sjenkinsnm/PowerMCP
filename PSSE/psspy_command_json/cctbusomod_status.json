{
  "module": "psspy",
  "function_name": "cctbusomod_status",
  "category": "Cct Models",
  "description": "Use this API to change status of an “other” type model attached to a bus. This API routine was first introduced in release 33.0.0. ierr = cctbusomod_status(ibus, model, status)",
  "python_syntax": "ierr = cctbusomod_status(ibus, model, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input; no default allowed)."
    },
    {
      "name": "model",
      "description": "Name of the model whose status is to be changed. (input; no default allowed)."
    },
    {
      "name": "status",
      "description": "New model status. (input; 1 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "status": [
      {
        "value": "= 0",
        "description": "out-of-service."
      },
      {
        "value": "= 1",
        "description": "in-service."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "no bus other model at this bus."
    },
    {
      "value": "= 2",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 3",
      "description": "bus not found."
    },
    {
      "value": "= 4",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}