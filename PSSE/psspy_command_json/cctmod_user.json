{
  "module": "psspy",
  "function_name": "cctmod_user",
  "category": "Cct Models",
  "description": "Use this API to list or remove user-written CCT model definitions. This API routine was first introduced in release 33.0.0. ierr = cctmod_user(opt)",
  "python_syntax": "ierr = cctmod_user(opt)",
  "return_type": "error_only_listing",
  "parameters": [
    {
      "name": "opt",
      "description": "Option code. (input; 0 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "opt": [
      {
        "value": "= 0",
        "description": "list user-written model definitions."
      },
      {
        "value": "= 1",
        "description": "remove unused user-written model definitions."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid OPT value."
    },
    {
      "value": "= 2",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}