{
  "module": "psspy",
  "function_name": "stbskv",
  "category": "Single Element Data",
  "description": "Use this API to restrict ‘NXTBUS’ to a single base voltage level. It must be called after INIBUS / INIBUX / ININAM / ININAX. This API routine was first introduced in release 28.0.0. ierr = stbskv(bskv)",
  "python_syntax": "ierr = stbskv(bskv)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "bskv",
      "description": "Base kv level. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error."
    },
    {
      "value": "= 1",
      "description": "Negative base voltage."
    }
  ]
}