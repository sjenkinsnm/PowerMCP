{
  "module": "psspy",
  "function_name": "scenariogroupremove",
  "category": "Scenarios",
  "description": "Use this API to remove a group from the Scenario. This API routine was first introduced in release 33.0.0. ierr = scenariogroupremove (sgroup)",
  "python_syntax": "ierr = scenariogroupremove (sgroup)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "sgroup",
      "description": "Name of the group to be removed from the scenario. (input; no default allowed)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error occurred."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "no Scenario in memory."
    },
    {
      "value": "= 3",
      "description": "specified group not found."
    }
  ]
}