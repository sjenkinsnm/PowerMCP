{
  "module": "psspy",
  "function_name": "station_branch_term_chng",
  "category": "Node Breaker Data",
  "description": "Use this API to access existing station branch terminal data in the working case. This API routine was first introduced in release 34.0.0. ierr = station_branch_term_chng(ibus, jbus, cktarg, nodes)",
  "python_syntax": "ierr = station_branch_term_chng(ibus, jbus, cktarg, nodes)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "ibus",
      "description": "From bus number. (input)."
    },
    {
      "name": "jbus",
      "description": "To bus number. (input)."
    },
    {
      "name": "cktarg",
      "description": "Circuit identifier. (input)."
    },
    {
      "name": "nodes",
      "description": "An array of two elementsNone. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error return. (output)."
    }
  ],
  "allowed_values": {
    "nodes": [
      {
        "value": "NODES(1)",
        "description": "from node number."
      },
      {
        "value": "NODES(2)",
        "description": "to node number."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "bus does not exist."
    },
    {
      "value": "= 2",
      "description": "bus does not belong to a substation."
    },
    {
      "value": "= 3",
      "description": "node does not exist in substation."
    },
    {
      "value": "= 4",
      "description": "invalid node number."
    },
    {
      "value": "= 5",
      "description": "circuit identifier is more than two characters."
    },
    {
      "value": "= 6",
      "description": "circuit identifier may not start with &"
    },
    {
      "value": "= 7",
      "description": "circuit not found."
    },
    {
      "value": "= 8",
      "description": "error when moving branch terminal connection."
    },
    {
      "value": "= 9",
      "description": "node-breaker terminal connection table is full."
    },
    {
      "value": "= 10",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}