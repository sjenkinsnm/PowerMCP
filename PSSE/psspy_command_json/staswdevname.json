{
  "module": "psspy",
  "function_name": "staswdevname",
  "category": "Single Element Data",
  "description": "Use this API routine to return the name of a substation switching device. This API routine was first introduced in release 34.1.0. ierr, string = staswdevname(ista, inode, jnode, id)",
  "python_syntax": "ierr, string = staswdevname(ista, inode, jnode, id)",
  "return_type": "error_and_string",
  "parameters": [
    {
      "name": "ista",
      "description": "Substation number. (input)."
    },
    {
      "name": "inode",
      "description": "“from” node number. (input)."
    },
    {
      "name": "jnode",
      "description": "“to” node number. (input)."
    },
    {
      "name": "id",
      "description": "Switching device identifier. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "string",
      "description": "Switching device name. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error; ‘STRING’ returned."
    },
    {
      "value": "= 1",
      "description": "substation not found; ‘STRING’ unchanged."
    },
    {
      "value": "= 2",
      "description": "node not found; ‘STRING’ unchanged."
    },
    {
      "value": "= 3",
      "description": "switching device not found; ‘STRING’ unchanged."
    }
  ]
}