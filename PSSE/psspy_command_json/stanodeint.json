{
  "module": "psspy",
  "function_name": "stanodeint",
  "category": "Single Element Data",
  "description": "Use this API routine to return integer substation values. This API routine was first introduced in release 34.1.0. ierr, ival = stanodeint(ista, node, string)",
  "python_syntax": "ierr, ival = stanodeint(ista, node, string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ista",
      "description": "Substation number. (input)."
    },
    {
      "name": "node",
      "description": "Node number. (input)."
    },
    {
      "name": "string",
      "description": "String indicating the quantity desired. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "ival",
      "description": "Value indicated by string. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= BUS",
        "description": "Bus number of the bus section to which the node is connected."
      },
      {
        "value": "= SECTION",
        "description": "Section number of the bus section to which the node is connected."
      },
      {
        "value": "= STATUS",
        "description": "Node status."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘IVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Substation not found; ‘IVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Node not found; ‘IVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Invalid value of ‘STRING’; ‘IVAL’ unchanged."
    }
  ]
}