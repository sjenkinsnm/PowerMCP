{
  "module": "psspy",
  "function_name": "areint",
  "category": "Single Element Data",
  "description": "Use this API to return integer area data items. This API routine was first introduced in release 28.0.0. ierr, ival = areint(iar, string)",
  "python_syntax": "ierr, ival = areint(iar, string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "iar",
      "description": "Area number. (input)."
    },
    {
      "name": "string",
      "description": "String indicating the area quantity desired. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "ival",
      "description": "Value indicated by string. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= SWING",
        "description": "Area slack bus number."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘IVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Area number <= 0 or > largest allowable area number; ‘IVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Area not found; ‘IVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Bad ‘STRING’ value; ‘IVAL’ unchanged."
    }
  ]
}