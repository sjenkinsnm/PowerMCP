{
  "module": "psspy",
  "function_name": "wnlist",
  "category": "Dynamic Simulation Operation",
  "description": "Use this API to list wind models connected to subsystem buses along with their storage locations in the dynamics data arrays. This API routine was first introduced in release 31.0.0. ierr = wnlist(sid, all, status)",
  "python_syntax": "ierr = wnlist(sid, all, status)",
  "return_type": "error_only_listing",
  "parameters": [
    {
      "name": "sid",
      "description": "Subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "An array of two elements specifying API options. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      },
      {
        "value": "= 1",
        "description": "process all buses."
      }
    ],
    "status": [
      {
        "value": "STATUS(1)",
        "description": "active/bypassed flag (0 by default)."
      },
      {
        "value": "= 0",
        "description": "active and bypassed models."
      },
      {
        "value": "= 1",
        "description": "active models only."
      },
      {
        "value": "= 2",
        "description": "bypassed models only."
      },
      {
        "value": "STATUS(2)",
        "description": "wind model type (1 by default)."
      },
      {
        "value": "= 1",
        "description": "all wind models."
      },
      {
        "value": "= 2",
        "description": "wind generator models."
      },
      {
        "value": "= 3",
        "description": "wind electrical models."
      },
      {
        "value": "= 4",
        "description": "wind mechanical models."
      },
      {
        "value": "= 5",
        "description": "wind pitch models."
      },
      {
        "value": "= 6",
        "description": "wind aerodynamic models."
      },
      {
        "value": "= 7",
        "description": "wind gust models."
      },
      {
        "value": "= 8",
        "description": "wind auxiliary signal models."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid SID value or subsystem SID is not defined."
    },
    {
      "value": "= 2",
      "description": "invalid ALL value."
    },
    {
      "value": "= 3",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 4",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}