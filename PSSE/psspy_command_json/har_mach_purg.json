{
  "module": "psspy",
  "function_name": "har_mach_purg",
  "category": "Harmonics Data",
  "description": "Use this API to purge specified harmonics machine data from the working case. This API routine was first introduced in release 35.4.0. ierr = har_mach_purg(ibus,id)",
