    },
    {
      "name": "id",
      "description": "Mach identifier. (input; ‘1’ by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error occurred."
    },
