{
  "module": "psspy",
  "function_name": "chsb",
  "category": "Dynamic Simulation Output Channel Operation",
  "description": "Use this API to specify, on a subsystem basis, the simulation variables to monitor during dynamic simulation runs (activity CHSB). This API routine was first introduced in release 28.0.0. ierr = chsb(sid, all, status)",
  "python_syntax": "ierr = chsb(sid, all, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "sid",
      "description": "Valid area, bus, owner, or zone subsystem identifier. valid subsystem identifiers range from 0 to 11. area, bus, owner, or zone subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "An array of six elementsNone. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 1",
        "description": "process all buses."
      },
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      }
    ],
    "status": [
      {
        "value": "STATUS(1)",
        "description": "starting channel index, or -1 for the next available (next available by default)."
      },
      {
        "value": "STATUS(2)",
        "description": "starting VAR index, or -1 for the next available (next available by default)."
      },
      {
        "value": "STATUS(3)",
        "description": "starting ICON index, or -1 for the next available (next available by default)."
      },
      {
        "value": "STATUS(4)",
        "description": "used to indicate the type of quantities to be placed in channels (1 by default)."
      },
      {
        "value": "= 1",
        "description": "machine, bus, load, branch quantities by bus subsystem."
      },
      {
        "value": "= 2",
        "description": "tie quantity by area subsystem."
      },
      {
        "value": "= 3",
        "description": "tie quantity by zone subsystem."
      },
      {
        "value": "= 4",
        "description": "power totals for an area subsystem."
      },
      {
        "value": "= 5",
        "description": "power totals for a zone subsystem."
      },
      {
        "value": "= 6",
        "description": "power totals for an owner subsystem."
