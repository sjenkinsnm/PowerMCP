{
  "module": "psspy",
  "function_name": "immod_unconnected",
  "category": "Induction Machine Models",
  "description": "Use this API to list or remove from dynamics working memory those induction machine models that are assigned to machines that are not present in the current power flow working case (unconnected). This API routine was first introduced in release 33.0.0. ierr = immod_unconnected(opt)",
  "python_syntax": "ierr = immod_unconnected(opt)",
  "return_type": "error_only_listing",
  "parameters": [
    {
      "name": "opt",
      "description": "Option code. (input; 0 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "opt": [
      {
        "value": "= 0",
        "description": "list unconnected induction machine models."
      },
      {
        "value": "= 1",
        "description": "remove unconnected induction machine models."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid OPT value."
    },
    {
      "value": "= 2",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}