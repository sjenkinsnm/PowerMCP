{
  "module": "psspy",
  "function_name": "time",
  "category": "Power Flow Operation",
  "description": "Use this API to tabulate timing statistics. This API routine was first introduced in release 29.0.0. ierr = time(init)",
  "python_syntax": "ierr = time(init)",
  "return_type": "error_only_report",
  "parameters": [
    {
      "name": "init",
      "description": "Timing flag. (input; positive by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "init": [
      {
        "value": "<= 0",
        "description": "do not initialize."
      },
      {
        "value": "> 0",
        "description": "initialize."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error occurred."
    },
    {
      "value": "= 1",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}