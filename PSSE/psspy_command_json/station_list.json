{
  "module": "psspy",
  "function_name": "station_list",
  "category": "Node Breaker Operation",
  "description": "Use this API to list components in a substation. This API routine was first introduced in release 34.0.0. ierr = station_list(option, station)",
  "python_syntax": "ierr = station_list(option, station)",
  "return_type": "error_only_listing",
  "parameters": [
    {
      "name": "option",
      "description": "None. (input)."
    },
    {
      "name": "station",
      "description": "Substation number. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "option": [
      {
        "value": "= 1",
        "description": "list all substations."
      },
      {
        "value": "= 2",
        "description": "list substation STATION."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no errors occurred."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "invalid OPTION value."
    },
    {
      "value": "= 2",
      "description": "invalid STATION number."
    },
    {
      "value": "= 3",
      "description": "STATION does not exist."
    },
    {
      "value": "= 4",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}