{
  "module": "psspy",
  "function_name": "station_pout_2",
  "category": "Node Breaker Operation",
  "description": "Use this API to print power flows within a substation. This API routine was first introduced in release 34.6.0. ierr = station_pout_2(all, station, option)",
  "python_syntax": "ierr = station_pout_2(all, station, option)",
  "return_type": "error_only_report",
  "parameters": [
    {
      "name": "all",
      "description": "None. (input)."
    },
    {
      "name": "station",
      "description": "Substation number. (input)."
    },
    {
      "name": "option",
      "description": "(input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 1",
        "description": "report the power flows of all substations."
      },
      {
        "value": "= 2",
        "description": "report the power flows of substation STATION."
      }
    ],
    "option": [
      {
        "value": "= 0",
        "description": "Do not display loop flow values."
      },
      {
        "value": "= 1",
        "description": "Show all flow values."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no errors occurred."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "invalid ALL value."
    },
    {
      "value": "= 2",
      "description": "invalid STATION number."
    },
    {
      "value": "= 3",
      "description": "STATION does not exist."
    },
    {
      "value": "= 4",
      "description": "invalid OPTION value."
    },
    {
      "value": "= 5",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}