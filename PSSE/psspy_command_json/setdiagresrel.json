{
  "module": "psspy",
  "function_name": "setdiagresrel",
  "category": "Diagram View",
  "description": "This API routine is obsolete. It has been replaced by the API routine setdiagresrel_2, and is implemented by a call to setdiagresrel_2. Use this API to specify the reliability annotation options in the active Slider diagram. This API routine was first introduced in release 31.0.0. setdiagresrel(outmode, mode, busmode, cntbus, cntbrn, detbus, detbrn, prbbus, prbbrn, voltrec, cntlabel, cntlist)",
  "python_syntax": "setdiagresrel(outmode, mode, busmode, cntbus, cntbrn, detbus, detbrn, prbbus, prbbrn, voltrec, cntlabel, cntlist)",
  "return_type": "void",
  "parameters": [
    {
      "name": "outmode",
      "description": "Mode of results displayed. (input)."
    },
    {
      "name": "mode",
      "description": "Type of reliability results displayed. (input)."
    },
    {
      "name": "busmode",
      "description": "Mode of bus reporting. (input)."
    },
    {
      "name": "cntbus",
      "description": "If mode = 0, is the option to specify whether bus voltage is displayed. (input)."
    },
    {
      "name": "cntbrn",
      "description": "If mode = 0, is the option to specify whether branch flow loading is displayed. (input)."
    },
    {
      "name": "detbus",
      "description": "If mode = 1, is the option to specify which bus voltage violations are displayed. non-zero values may be summed. (input)."
    },
    {
      "name": "detbrn",
      "description": "If mode = 1, is the option to specify which branch flow overloading violations are displayed. (input)."
    },
    {
      "name": "prbbus",
      "description": "If mode = 2, is the option to specify which bus voltage violations are displayed. (input)."
    },
    {
      "name": "prbbrn",
      "description": "If mode = 2, is the option to specify which branch flow overloading violations are displayed. (input)."
    },
    {
      "name": "voltrec",
      "description": "Index into the voltage limit record array for the current dfax file. (input)."
    },
    {
      "name": "cntlabel",
      "description": "Contingency to display results for. (input)."
    },
    {
      "name": "cntlist",
      "description": "What contingencies are listed for selection. (input)."
    }
  ],
  "return_values": [],
