{
  "module": "psspy",
  "function_name": "tspfprofilereal",
  "category": "Single Element Data",
  "description": "Use this API to return real parameters of Time Series Power Flow profile. This API routine was first introduced in release 35.4.0. ierr, rval = tspfprofilereal(name,string)",
  "python_syntax": "ierr, rval = tspfprofilereal(name,string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "name",
      "description": "Profile name. (input)."
    },
    {
      "name": "string",
      "description": "String indicating name of the real parameter desired. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "The error code . (output)."
    },
    {
      "name": "rval",
      "description": "Value indicated by string. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= OFFSET",
        "description": "Offset."
      },
      {
        "value": "= SCALEFACTOR",
        "description": "Scale factor."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘RVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Profile not found; ‘RVAL’ unchanged."
    }
  ]
}