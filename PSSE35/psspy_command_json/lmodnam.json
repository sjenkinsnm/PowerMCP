{
  "module": "psspy",
  "function_name": "lmodnam",
  "category": "Single Element Data",
  "description": "Returns load-related model name. This API routine was first introduced in release 28.0.0. ierr, cval = lmodnam(ibus, id ,string)",
  "python_syntax": "ierr, cval = lmodnam(ibus, id ,string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input)."
    },
    {
      "name": "id",
      "description": "Load identifier. (input)."
    },
    {
      "name": "string",
      "description": "String indicating the type of load model desired. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "cval",
      "description": "Model name. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= CHARAC",
        "description": "Load characteristic model."
      },
      {
        "value": "= RELAY",
        "description": "Load relay model."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘CVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Load not in network but in model tables; ‘CVAL’ returned."
    },
    {
      "value": "= 2",
      "description": "Load not in network or in model tables; ‘CVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Invalid value of ‘STRING’; ‘CVAL’ unchanged."
    },
    {
      "value": "= 4",
      "description": "No model of type ‘STRING’ for this load; ‘CVAL’ unchanged."
    },
    {
      "value": "= 9",
      "description": "Dynamics data not present in working memory; ‘CVAL’ unchanged."
    }
  ]
}