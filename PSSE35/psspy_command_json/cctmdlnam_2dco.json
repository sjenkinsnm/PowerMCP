{
  "module": "psspy",
  "function_name": "cctmdlnam_2dco",
  "category": "Single Element Data",
  "description": "Use this API to return model name of CCT 2-terminal dc line other models. This API routine was first introduced in release 35.0.0. ierr, model = cctmdlnam_2dco(name)",
  "python_syntax": "ierr, model = cctmdlnam_2dco(name)",
  "return_type": "error_and_model",
  "parameters": [
    {
      "name": "name",
      "description": "Two-terminal dc line name. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "model",
      "description": "Model name. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; MODEL name is returned."
    },
    {
      "value": "= 1",
      "description": "dc line not in case."
    },
    {
      "value": "= 2",
      "description": "No CCT models in case."
    },
    {
      "value": "= 3",
      "description": "No 2-terminal dc other model attached to the specified dc line."
    },
    {
      "value": "= 4",
      "description": "Dynamics data not present in working memory."
    }
  ]
}