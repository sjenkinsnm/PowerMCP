{
  "module": "psspy",
  "function_name": "cctbrnomod_status",
  "category": "Cct Models",
  "description": "Use this API to change the status of a branch “other” model attached to the specified branch. This API routine was first introduced in release 33.6.0. ierr = cctbrnomod_status(ibus, jbus, id, model, status)",
  "python_syntax": "ierr = cctbrnomod_status(ibus, jbus, id, model, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "ibus",
      "description": "From bus number. (input)."
    },
    {
      "name": "jbus",
      "description": "To bus number. (input; Not Allowed by default)."
    },
    {
      "name": "id",
      "description": "Circuit identifier. (input)."
    },
    {
      "name": "model",
      "description": "Model name. (input; no default allowed)."
    },
    {
      "name": "status",
      "description": "New model status. (input; 1 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "status": [
      {
        "value": "= 0",
        "description": "out-of-service."
      },
      {
        "value": "= 1",
        "description": "in-service."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "no branch other model on this branch."
    },
    {
      "value": "= 2",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 3",
      "description": "bus not found."
    },
    {
      "value": "= 4",
      "description": "branch not found."
    },
    {
      "value": "= 5",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}