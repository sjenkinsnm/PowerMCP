{
  "module": "psspy",
  "function_name": "gensectdt1",
  "category": "Single Element Data",
  "description": "Use this API routine to return a bus section’s total plant power output in MVA. This API routine was first introduced in release 34.1.0. ierr, rval = gensectdt1(ibus, sect)",
  "python_syntax": "ierr, rval = gensectdt1(ibus, sect)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input)."
    },
    {
      "name": "sect",
      "description": "Bus section number. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "rval",
      "description": "Magnitude of total plant generation. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘RVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Bus not found; ‘RVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Bus type code is not 2 or 3; ‘RVAL’ returned."
    },
    {
      "value": "= 3",
      "description": "No machines at bus; ‘RVAL’ unchanged."
    },
    {
      "value": "= 4",
      "description": "No online machines; ‘RVAL’ of 0.0 returned."
    },
    {
      "value": "= 9",
      "description": "Bus section not found; ‘RVAL’ unchanged."
    }
  ]
}