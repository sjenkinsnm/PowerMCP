{
  "module": "psspy",
  "function_name": "windmnam",
  "category": "Single Element Data",
  "description": "Use this API to return wind model name. This API routine was first introduced in release 31.0.0. ierr, cval = windmnam(ibus, id, string)",
  "python_syntax": "ierr, cval = windmnam(ibus, id, string)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input)."
    },
    {
      "name": "id",
      "description": "Machine identifier. (input)."
    },
    {
      "name": "string",
      "description": "String indicating the type of plant-related model. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "cval",
      "description": "Model name. (output)."
    }
  ],
  "allowed_values": {
    "string": [
      {
        "value": "= WGEN",
        "description": "Renewable Generator model."
      },
      {
        "value": "= WELEC",
        "description": "Renewable Electrical model."
      },
      {
        "value": "= WMECH",
        "description": "Renewable Mechanical model."
      },
      {
        "value": "= WPICH or WPITCH",
        "description": "Wind Pitch model."
      },
      {
        "value": "= WAERO",
        "description": "Wind Aerodynamic model."
      },
      {
        "value": "= WGUST",
        "description": "Wind Gust Model."
      },
      {
        "value": "= WAUX",
        "description": "Renewable Auxiliary Signal model."
      },
      {
        "value": "= WTRQ",
        "description": "Wind Torque Control model."
      },
      {
        "value": "= WWGO",
        "description": "Renewable Weak Grid model."
      },
      {
        "value": "= WPAUX",
        "description": "Renewable Paux Control model."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘CVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Machine not in network but in model tables; ‘CVAL’ returned."
    },
    {
      "value": "= 2",
      "description": "Machine not in network or in model tables; ‘CVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Invalid value of ‘STRING’, ‘CVAL’ unchanged."
    },
    {
      "value": "= 4",
      "description": "No model of type ‘STRING’ for this machine; ‘CVAL’ unchanged."
    },
    {
      "value": "= 9",
      "description": "Dynamics data not present in working memory; ‘CVAL’ unchanged."
    }
  ]
}