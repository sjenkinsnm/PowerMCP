  "return_type": "error_only",
  "parameters": [
    {
      "name": "ibus",
      "description": "Bus number. (input)."
    },
    {
      "name": "id",
      "description": "Machine identifier. (input)."
    },
    {
      "name": "intgar",
      "description": "An array of five elementsNone. (input)."
    },
    {
      "name": "realar",
      "description": "An array of sixteen elementsNone. (input)."
