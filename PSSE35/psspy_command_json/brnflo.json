{
  "module": "psspy",
  "function_name": "brnflo",
  "category": "Single Element Data",
  "description": "Use this API to return the complex branch flow (P+jQ) as calculated at IBUS. This API routine was first introduced in release 28.0.0. ierr, cmpval = brnflo(ibus,jbus,ickt)",
  "python_syntax": "ierr, cmpval = brnflo(ibus,jbus,ickt)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ibus",
      "description": "From bus number. (input)."
    },
    {
      "name": "jbus",
      "description": "To bus number. (input)."
    },
    {
      "name": "ickt",
      "description": "Circuit or multisection line identifier. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "cmpval",
      "description": "Complex branch flow. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘P’ and ‘Q’ or ‘CMPVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Bus not found; ‘P’ and ‘Q’ or ‘CMPVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Branch not found; ‘P’ and ‘Q’ or ‘CMPVAL’ unchanged."
    },
    {
      "value": "= 3",
      "description": "Branch is out-of-service; ‘P’ and ‘Q’ of 0.0 or ‘CMPVAL’ of (0.0,0.0) returned."
    }
  ]
}