{
  "module": "psspy",
  "function_name": "sqli",
  "category": "Power Flow Operation",
  "description": "Use this API to tabulate the sequence data in a form suitable for problem data documentation. This API routine was first introduced in release 28.0.0. ierr = sqli(sid, all, opt)",
  "python_syntax": "ierr = sqli(sid, all, opt)",
  "return_type": "error_only_report",
  "parameters": [
    {
      "name": "sid",
      "description": "A valid subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "opt",
      "description": "Category of sequence data to be tabulated. (input; 1 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      },
      {
        "value": "= 1",
        "description": "process all buses."
      }
    ],
    "opt": [
      {
        "value": "= 1",
        "description": "full listing."
      },
      {
        "value": "= 2",
        "description": "bus load data."
      },
      {
        "value": "= 3",
        "description": "generator data."
      },
      {
        "value": "= 4",
        "description": "branch data."
      },
      {
        "value": "= 5",
        "description": "two-winding positive sequence data."
      },
      {
        "value": "= 6",
        "description": "mutual coupling data."
      },
      {
        "value": "= 7",
        "description": "switched shunt data."
      },
      {
        "value": "= 8",
        "description": "three-winding general data."
      },
      {
        "value": "= 9",
        "description": "line shunt data."
      },
      {
        "value": "= 10",
        "description": "fixed shunt data."
      },
      {
        "value": "= 11",
        "description": "induction machine data."
      },
      {
        "value": "= 12",
        "description": "two-winding zero sequence data."
      },
      {
        "value": "= 13",
        "description": "three-winding positive sequence data."
      },
      {
        "value": "= 14",
        "description": "three-winding zero sequence data."
      },
      {
        "value": "= 15",
        "description": "non-conventional source machine data."
      },
      {
        "value": "= 16",
        "description": "non-conventional source table data."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error occurred."
    },
    {
      "value": "= 1",
      "description": "invalid SID value or subsystem SID is not defined."
    },
    {
      "value": "= 2",
      "description": "invalid ALL value."
    },
    {
      "value": "= 3",
      "description": "invalid OPT value."
    },
    {
      "value": "= 4",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}