{
  "module": "psspy",
  "function_name": "seq_ncs_table_type",
  "category": "Fault Analysis Data",
  "description": "Use this API to get NCS table type. This API routine was first introduced in release 35.2.0. ierr, ttyp = seq_ncs_table_type(name)",
  "python_syntax": "ierr, ttyp = seq_ncs_table_type(name)",
  "return_type": "error_and_value",
  "parameters": [
    {
      "name": "name",
      "description": "Table name. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "ttyp",
      "description": "Table type (1=time-current, 2=voltage-current. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "no errors occurred."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "table not found."
    },
    {
      "value": "= 2",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}