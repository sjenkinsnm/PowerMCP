{
  "module": "psspy",
  "function_name": "dyda",
  "category": "Dynamic Simulation Operation",
  "description": "Use this API to replicate dynamics model data in the form of a Dynamics Data Input file. This API routine was first introduced in release 28.0.0. ierr = dyda(sid, all, status, out, ofile)",
  "python_syntax": "ierr = dyda(sid, all, status, out, ofile)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "sid",
      "description": "A valid subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "An array of three elements specifying a three-element array. (input)."
    },
    {
      "name": "out",
      "description": "Destination selection. (input; 1 by default)."
    },
    {
      "name": "ofile",
      "description": "Name of the file to which data records are to be written (when out is 0). (input; no default allowed)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 1",
        "description": "process all buses."
      },
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      }
    ],
    "status": [
      {
        "value": "STATUS(1)",
        "description": "models to process (2 by default)."
      },
      {
        "value": "= 0",
        "description": "process all CONEC models."
      },
      {
        "value": "= 1",
        "description": "process all CONET models."
      },
      {
        "value": "= 2",
        "description": "process models by subsystem."
      },
      {
        "value": "= 3",
        "description": "process Miscellaneous other type models."
      },
      {
        "value": "STATUS(2)",
        "description": "value depends on the value of STATUS(1). If STATUS(1) = 2 then STATUS(2) is the type of model for which data is to be processed (1 by default)."
