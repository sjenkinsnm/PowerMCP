{
  "module": "psspy",
  "function_name": "setdiagresscgr",
  "category": "Diagram View",
  "description": "Use this API to specify the short circuit analysis voltage and range checking annotation options in the active Slider diagram. This API routine was first introduced in release 30.0.0. setdiagresscgr(usevlt, vlnwdt, vlnsty, vltval, vlnclrr, vlnclrg, vlnclrb, outwdt, outsty, outclr, fltwdt, fltsty, fltclr, busann)",
  "python_syntax": "setdiagresscgr(usevlt, vlnwdt, vlnsty, vltval, vlnclrr, vlnclrg, vlnclrb, outwdt, outsty, outclr, fltwdt, fltsty, fltclr, busann)",
  "return_type": "void",
  "parameters": [
    {
      "name": "usevlt",
      "description": "Flag to apply voltage level annotation to the diagram elements. (input)."
    },
    {
      "name": "vlnwdt",
      "description": "An array of eight elements specifying width of diagram elements that fall in the appropriate voltage range. (input)."
    },
    {
      "name": "vlnsty",
      "description": "An array of eight elements specifying line style of diagram elements that fall in the appropriate voltage range. (input)."
    },
    {
      "name": "vltval",
      "description": "An array of 7 elements specifying voltage ranges used to assign annotation diagram. Base voltage values should be in ascending order. (input)."
    },
    {
      "name": "vlnclrr",
      "description": "An array of eight elements specifying set the Red color component of diagram elements that fall in the appropriate voltage range, 0->255. (input)."
    },
    {
      "name": "vlnclrg",
      "description": "An array of eight elements specifying set Green color component of diagram elements that fall in the appropriate voltage range, 0->255. (input)."
    },
    {
      "name": "vlnclrb",
      "description": "An array of eight elements specifying set Blue color component of diagram elements that fall in the appropriate voltage range, 0->255. (input)."
    },
    {
      "name": "outwdt",
      "description": "Line width applied to out of service diagram items, >= 1. (input)."
    },
    {
      "name": "outsty",
      "description": "Line style applied to out of service diagram items. (input)."
    },
    {
      "name": "outclr",
      "description": "An array of three elements specifying color for diagram items that are out of service. (input)."
    },
    {
      "name": "fltwdt",
      "description": "Line width applied to the faulted bus diagram item, >= 1. (input)."
    },
    {
      "name": "fltsty",
      "description": "Line style applied to the faulted bus diagram item. (input)."
    },
    {
      "name": "fltclr",
      "description": "An array of three elements specifying color for Diagram items that are out of service. (input)."
    },
    {
      "name": "busann",
      "description": "Bus id annotation. (input)."
    }
  ],
