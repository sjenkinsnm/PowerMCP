{
  "module": "psspy",
  "function_name": "docu",
  "category": "Dynamic Simulation Operation",
  "description": "Use this API to tabulate the data associated with equipment models referenced in the user’s simulation setup. This API routine was first introduced in release 28.0.0. ierr = docu(sid, all, status)",
  "python_syntax": "ierr = docu(sid, all, status)",
  "return_type": "error_only_report",
  "parameters": [
    {
      "name": "sid",
      "description": "A valid subsystem identifier. valid subsystem identifiers range from 0 to 11. subsystem sid must have been previously defined. (input; 0 by default)."
    },
    {
      "name": "all",
      "description": "All buses or specified subsystem flag. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "An array of three elements specifying reporting options. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "all": [
      {
        "value": "= 1",
        "description": "process all buses."
      },
      {
        "value": "= 0",
        "description": "process only buses in subsystem SID."
      }
    ],
    "status": [
      {
        "value": "STATUS(1)",
        "description": "processing mode (0 by default)."
      },
      {
        "value": "= 0",
        "description": "reporting mode."
      },
      {
        "value": "= 1",
        "description": "data checking mode."
      },
      {
        "value": "STATUS(2)",
        "description": "models to process (3 by default)."
      },
      {
        "value": "= 0",
        "description": "process all CONEC models."
      },
      {
        "value": "= 1",
        "description": "process all CONET models."
      },
      {
        "value": "= 2",
        "description": "process all CHAN models."
      },
      {
        "value": "= 3",
