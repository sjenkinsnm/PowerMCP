{
  "module": "psspy",
  "function_name": "swsmod_unconnected",
  "category": "Switched Shunt Models",
  "description": "Use this API to list or remove from dynamics working memory those switched shunt models that are assigned to switched shunt that are not present in the current power flow working case (unconnected). This API routine was first introduced in release 31.0.0. ierr = swsmod_unconnected(opt)",
  "python_syntax": "ierr = swsmod_unconnected(opt)",
  "return_type": "error_only_listing",
  "parameters": [
    {
      "name": "opt",
      "description": "Option code. (input; 0 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "opt": [
      {
        "value": "= 0",
        "description": "list unconnected switched shunt models."
      },
      {
        "value": "= 1",
        "description": "remove unconnected switched shunt models."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid OPT value."
    },
    {
      "value": "= 2",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}