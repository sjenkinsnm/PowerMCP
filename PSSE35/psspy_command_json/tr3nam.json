{
  "module": "psspy",
  "function_name": "tr3nam",
  "category": "Single Element Data",
  "description": "Use this API to return three-winding transformer name. This API routine was first introduced in release 28.0.0. ierr, cval = tr3nam(ibus, jbus, kbus, ickt)",
  "python_syntax": "ierr, cval = tr3nam(ibus, jbus, kbus, ickt)",
  "return_type": "error_and_scalar",
  "parameters": [
    {
      "name": "ibus",
      "description": "From bus number. (input)."
    },
    {
      "name": "jbus",
      "description": "To bus number. (input)."
    },
    {
      "name": "kbus",
      "description": "Third bus number. (input)."
    },
    {
      "name": "ickt",
      "description": "Circuit identifier. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    },
    {
      "name": "cval",
      "description": "Transformer name. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error; ‘CVAL’ returned."
    },
    {
      "value": "= 1",
      "description": "Bus not found; ‘CVAL’ unchanged."
    },
    {
      "value": "= 2",
      "description": "Three-winding transformer not found; ‘CVAL’ unchanged."
    },
    {
      "value": "= 4",
      "description": "Error fetching transformer data; ‘CVAL’ unchanged."
    }
  ]
}