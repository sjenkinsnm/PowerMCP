{
  "module": "psspy",
  "function_name": "fetch_sws_shunt_term_node_2",
  "category": "Node Breaker Data",
  "description": "Use this API to obtain the terminal node to which a switched shunt is connected to. This API routine was first introduced in release 35.2. ierr,intgar = fetch_sws_shunt_term_node_2(ibus, cktarg)",
  "python_syntax": "ierr,intgar = fetch_sws_shunt_term_node_2(ibus, cktarg)",
  "return_type": "error_and_record",
  "parameters": [
    {
      "name": "ibus",
      "description": "From bus number. (input)."
    },
    {
      "name": "cktarg",
      "description": "Switched shunt identifier. (input)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error return. (output)."
    },
    {
      "name": "intgar",
      "description": "Node terminal number. (output)."
    }
  ],
  "error_codes": [
    {
      "value": "= 0",
      "description": "No error."
    },
    {
      "value": "> 0",
      "description": "fatal error occurred."
    },
    {
      "value": "= 1",
      "description": "bus does not exist."
    },
    {
      "value": "= 2",
      "description": "switched shunt identifier is more than two characters."
    },
    {
      "value": "= 3",
      "description": "switched shunt not found."
    }
  ]
}