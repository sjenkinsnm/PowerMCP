{
  "module": "psspy",
  "function_name": "ldmod_status",
  "category": "Load Related Models",
  "description": "Use this API to change the status of a load related model of a designated type for all subsystem loads at which it is applied. This API routine was first introduced in release 28.0.0. ierr = ldmod_status(mtype, ibus, id, ltype, status)",
  "python_syntax": "ierr = ldmod_status(mtype, ibus, id, ltype, status)",
  "return_type": "error_only",
  "parameters": [
    {
      "name": "mtype",
      "description": "Subsystem type. (input; 0 by default)."
    },
    {
      "name": "ibus",
      "description": "Bus, owner, zone or area number. ignored when mtype is 4 (when mtype is less than 4). (input; no default allowed)."
    },
    {
      "name": "id",
      "description": "Load identifier, or “*” if the model is applied to all loads in the subsystem. (input; blank by default)."
    },
    {
      "name": "ltype",
      "description": "Load model type. (input; 1 by default)."
    },
    {
      "name": "status",
      "description": "New model status. (input; 1 by default)."
    }
  ],
  "return_values": [
    {
      "name": "ierr",
      "description": "Error code. (output)."
    }
  ],
  "allowed_values": {
    "mtype": [
      {
        "value": "= 0",
        "description": "bus model."
      },
      {
        "value": "= 1",
        "description": "owner model."
      },
      {
        "value": "= 2",
        "description": "zone model."
      },
      {
        "value": "= 3",
        "description": "area model."
      },
      {
        "value": "= 4",
        "description": "all model."
      }
    ],
    "ltype": [
      {
        "value": "= 1",
        "description": "load characteristic model."
      },
      {
        "value": "= 2",
        "description": "load relay model."
      }
    ],
    "status": [
      {
        "value": "= 0",
        "description": "out-of-service."
      },
      {
        "value": "= 1",
        "description": "in-service."
      }
    ]
  },
  "error_codes": [
    {
      "value": "= 0",
      "description": "no error."
    },
    {
      "value": "= 1",
      "description": "invalid number specified for IBUS."
    },
    {
      "value": "= 2",
      "description": "invalid LTYPE value."
    },
    {
      "value": "= 3",
      "description": "invalid MTYPE value."
    },
    {
      "value": "= 4",
      "description": "no all type LTYPE model for this id in tables."
    },
    {
      "value": "= 5",
      "description": "no MTYPE type LTYPE model for this id in tables for MTYPE IBUS."
    },
    {
      "value": "= 6",
      "description": "invalid STATUS value."
    },
    {
      "value": "= 7",
      "description": "prerequisite requirements for API are not met."
    }
  ]
}